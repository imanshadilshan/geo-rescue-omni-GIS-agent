# Large ML model files — download separately, do not commit
*.safetensors
*.pt
*.bin
*.ckpt
*.pth
*.h5
*.pkl

# Runtime-generated GIS output (not training data)
ml_serving/data/processed/blocked_roads_flood.geojson
ml_serving/data/processed/latest_route.geojson
ml_serving/data/processed/latest_status.json
ml_serving/data/processed/live_flood_polygon.geojson

# Large satellite images — store locally, do not commit
ml_serving/data/raw/*.png

# OSMnx binary graph cache
ml_serving/data/processed/*.graphml
cache/
*.graphml

