# ─── GeoRescue Omni GIS Agent — Environment Template ───────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values (anything marked <REQUIRED>)
# 3. Never commit .env — it is gitignored

# ── Map defaults (Colombo Fort, Sri Lanka) ───────────────────────────────────
MAP_CENTER_LAT=6.9271
MAP_CENTER_LON=79.8612
MAP_DEFAULT_ZOOM=12
MAP_GRAPH_RADIUS_KM=12
DEFAULT_SPEED_KMH=30

# ── GIS & Vision API server ───────────────────────────────────────────────────
# Start: cd ml_serving && uvicorn api.app:app --host 0.0.0.0 --port 9000
GIS_API_URL=http://localhost:9000
GIS_API_TIMEOUT_SHORT=15
GIS_API_TIMEOUT_LONG=120

# ── Qwen2-VL LoRA adapter ─────────────────────────────────────────────────────
# Relative to ml_serving/ directory. Download from HuggingFace or use training/.
# See ml_serving/final3/README.md for instructions.
ADAPTER_PATH=final3

# ── Ollama LLM ───────────────────────────────────────────────────────────────
# Download Ollama: https://ollama.com/download
# Pull model:      ollama pull llama3.2
# Alternatives:    llama3.1:8b (better tool-use), mistral:7b (faster)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Sentinel Hub (satellite imagery pipeline) ────────────────────────────────
# Register at: https://apps.sentinel-hub.com/dashboard/#/account/settings
# Create OAuth client → copy Client ID and Secret below
SENTINEL_CLIENT_ID=<REQUIRED>
SENTINEL_CLIENT_SECRET=<REQUIRED>

# ── App settings ─────────────────────────────────────────────────────────────
APP_TITLE=GeoRescue — Omni GIS Agent
APP_ICON=🛰️
LOG_LEVEL=INFO

# ── Default routing points (Colombo Fort → Pettah area) ─────────────────────
DEFAULT_START_LAT=6.9171
DEFAULT_START_LON=79.8512
DEFAULT_DEST_LAT=6.9371
DEFAULT_DEST_LON=79.8712
